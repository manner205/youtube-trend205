# .env.example
# 실제 키 값은 .env 파일에 저장해. 이 파일은 형식만 보여주는 예시야.
# .env 파일은 절대 git에 올리지 마. .gitignore에 이미 추가돼 있어.

# ── YouTube Data API v3 ──────────────────────
# Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > API 키
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Anthropic (Claude API) ───────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Notion ───────────────────────────────────
# notion.so/profile/integrations > 새 통합 생성 > 시크릿 토큰
NOTION_TOKEN=your_notion_integration_token_here
# 데이터를 저장할 Notion 데이터베이스 ID (URL에서 복사)
NOTION_DATABASE_ID=your_notion_database_id_here

# ── Gmail ────────────────────────────────────
# Google Cloud Console > OAuth 2.0 클라이언트 ID (credentials.json으로 저장)
GMAIL_SENDER=manner205@gmail.com
GMAIL_RECIPIENT=manner205@gmail.com

# ── 리포트 설정 ───────────────────────────────
# Claude 분석에 사용할 모델 (기본값: claude-haiku-4-5-20251001 = 빠르고 저렴)
CLAUDE_MODEL=claude-haiku-4-5-20251001
